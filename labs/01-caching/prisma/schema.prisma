generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Synthetic product catalog — the "hot read" table this lab caches in front of.
model Product {
  id        Int      @id @default(autoincrement())
  sku       String   @unique
  name      String
  price     Float
  updatedAt DateTime @updatedAt

  @@map("products")
}
