# Copy this file to .env and adjust as needed.
NODE_ENV=development

# Postgres (matches docker-compose.yml — host port 5433 to avoid clashing with other local projects)
DATABASE_URL=postgresql://labs:labs@localhost:5433/labs

# Redis (matches docker-compose.yml — host port 6380 to avoid clashing with other local projects)
REDIS_URL=redis://localhost:6380

# Lab 01 — Caching
LAB01_PORT=3001
# Artificial delay added to every DB read, so the cache-off baseline has a
# visible cost (real disks/networks aren't as fast as localhost Postgres).
LAB01_DB_LATENCY_MS=50
CACHE_ENABLED=true
CACHE_TTL_SECONDS=60

# Lab 02 — Pub/Sub + god-service decomposition
ARCHITECTURE=events
SIMULATE_CHARGE_FAILURE=false
SIMULATE_EMAIL_FAILURE=false

# Lab 03 — Background workers
SYNC_MODE=false
